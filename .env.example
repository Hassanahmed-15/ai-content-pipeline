# Copy to .env and fill in to go LIVE. Without a key, the pipeline runs
# end-to-end using a deterministic stub. Keys are read from here only --
# never hardcoded in source.

# Which provider to use: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# --- OpenAI (default) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic / Claude (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# OUTPUT_DIR=./output
